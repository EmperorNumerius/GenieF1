# Groq API key for llama3-8b-8192 AI inference (race engineer, insights, strategy calls)
GROQ_API_KEY=

# Stripe secret key — used for checkout session creation and webhook verification
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (starts with whsec_)
STRIPE_WEBHOOK_SECRET=

# Discord bot token for the live race-insight broadcaster bot
DISCORD_BOT_TOKEN=

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000

# Set to "production" to disable the /api/unlock_dev endpoint
ENVIRONMENT=development
